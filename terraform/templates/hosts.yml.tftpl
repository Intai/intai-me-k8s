all:
  vars:
    ansible_user: ubuntu
    ansible_ssh_private_key_file: ~/.ssh/id_rsa
    ansible_ssh_common_args: "-o StrictHostKeyChecking=accept-new"
  hosts:
%{ for server in servers ~}
    ${server.name}:
      ansible_host: ${server.ip}
      vm_ip: ${server.vm_ip}
      wg_ip: ${server.wg_ip}
      node_name: ${server.node_name}
%{ endfor ~}
  children:
    hosts:
      hosts:
%{ for server in servers ~}
        ${server.name}: {}
%{ endfor ~}
